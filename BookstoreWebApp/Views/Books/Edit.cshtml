@using BookstoreProjectCore.Models.Books;
@model BooksEditViewModel

<h1 style="font-family: Arial;">Edit this book</h1>
<form asp-action="Edit" method="post">
    <div class="mb-3">
        <label asp-for="Title" class="form-label">New title</label>
        <input asp-for="Title" class="form-control" required />
    </div>
    <div class="mb-3">
        <label asp-for="Price" class="form-label">New price</label>
        <input asp-for="Price" type="number" step="0.01" class="form-control" required />
    </div>
    <div class="mb-3">
        <label asp-for="CoverImageUrl" class="form-label">New cover URL: </label>
        <input asp-for="CoverImageUrl" class="form-control"  />
    </div>
    <div class="mb-3">
        <label asp-for="Synopsis" class="form-label"> Synopsis </label>
        <input asp-for="Synopsis" class="form-control" required />
    </div>
    <div class="mb-3">
        <label asp-for="AuthorId" class="form-label">Author</label>
        <select asp-for="AuthorId" class="form-control" asp-items="ViewBag.Authors" required></select>
    </div>
    <div class="mb-3">
        <label asp-for="GenreId" class="form-label">Genre</label>
        <select asp-for="GenreId" class="form-control" asp-items="ViewBag.Genres" required></select>
    </div>
     
    <div class="mb-3">
        <button type="submit" class="btn btn-primary">Edit</button>
    </div>
</form>
