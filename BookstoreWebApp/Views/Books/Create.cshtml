@using BookstoreProjectCore.Models.Books;
@model BooksCreateViewModel

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<h1 style="font-family: Arial;">Add a new book</h1>
<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="Title" class="form-label">Title</label>
        <input asp-for="Title" class="form-control" required />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Price" class="form-label">Price</label>
        <input asp-for="Price" type="number" step="0.01" class="form-control" required />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="CoverImageUrl" class="form-label">Cover URL: </label>
        <input asp-for="CoverImageUrl" class="form-control" />
        <span asp-validation-for="CoverImageUrl" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Synopsis" class="form-label">Synopsis: </label>
        <input asp-for="Synopsis" class="form-control" required />
        <span asp-validation-for="Synopsis" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="AuthorId" class="form-label">Select author</label>
        <select asp-for="AuthorId" class="form-control" asp-items="ViewBag.Authors" required></select>
        <span asp-validation-for="AuthorId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="GenreId" class="form-label">Select genre</label>
        <select asp-for="GenreId" class="form-control" asp-items="ViewBag.Genres" required></select>
        <span asp-validation-for="GenreId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <button type="submit" class="btn btn-primary">Create</button>
    </div>
</form>


<script src="~/lib/jquery-validation/dist/jquery.validate.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>