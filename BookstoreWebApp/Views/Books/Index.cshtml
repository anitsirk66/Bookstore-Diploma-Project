<div class="container-fluid">
    <div class="row">

        <aside class="col-md-3 col-lg-2 bg-light p-3 border-end">

            <form method="get" asp-controller="Books" asp-action="Index">

                <h5 class="fw-bold">Filters</h5>
                <hr />

                <h6 class="mt-3">Genre</h6>
                @foreach (var genre in ViewBag.Genres)
                {
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="genreIds" value="@genre.Id" />
                        <label class="form-check-label">@genre.Name</label>
                    </div>
                }

                <h6 class="mt-4">Author</h6>
                @foreach (var author in ViewBag.Authors)
                {
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="authorIds" value="@author.Id" />
                        <label class="form-check-label">@author.FullName</label>
                    </div>
                }

                <h6 class="mt-4">Publisher</h6>
                @foreach (var publisher in ViewBag.Publishers)
                {
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="publisherIds" value="@publisher.Id" />
                        <label class="form-check-label">@publisher.Name</label>
                    </div>
                }

                <button type="submit" class="btn btn-dark w-100 mt-4">Apply Filters</button>
                <a asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">Reset</a>

            </form>
        </aside>


        <section class="col-md-9 col-lg-10 p-4">

            <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">

                <form method="get" asp-controller="Books" asp-action="Index" class="w-100 w-md-50">
                    <div class="input-group">
                        <input type="text" name="searchItem" class="form-control"
                               placeholder="Search books, authors..." />
                        <button class="btn btn-dark">🔍</button>
                    </div>
                </form>

                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Create" class="btn btn-primary">Add Book</a>
                }

            </div>

            <h2 class="mb-4">Books</h2>

            <div class="row g-4">
                @foreach (var book in Model)
                {
                    <div class="col-sm-6 col-md-4 col-lg-3">

                        <div class="card h-100 shadow-sm">

                            <a asp-action="Details" asp-route-id="@book.Id" class="text-decoration-none text-dark">
                                <img src="@book.CoverImageUrl" class="card-img-top" style="height:250px; object-fit:cover;" />

                                <div class="card-body">
                                    <h6 class="fw-bold">@book.Title</h6>
                                    <p class="text-muted small mb-1">@book.AuthorName</p>
                                    <p class="fw-semibold">@book.Price €</p>
                                </div>
                            </a>

                            <div class="card-footer bg-white border-0">

                                @if (User.IsInRole("Admin"))
                                {
                                    <div class="d-flex gap-2">
                                        <a asp-action="Edit" asp-route-id="@book.Id"
                                           class="btn btn-warning btn-sm w-100">Edit</a>

                                        <form asp-action="Delete" method="get" class="w-100">
                                            <input type="hidden" name="id" value="@book.Id" />
                                            <button class="btn btn-danger btn-sm w-100">Delete</button>
                                        </form>
                                    </div>
                                }
                                else if (User.Identity.IsAuthenticated && User.IsInRole("Client"))
                                {
                                    <a asp-controller="Orders"
                                       asp-action="AddToCart"
                                       asp-route-id="@book.Id"
                                       class="btn btn-dark w-100">
                                        Add to Cart
                                    </a>
                                }

                            </div>

                        </div>

                    </div>
                }
            </div>

        </section>
    </div>
</div>