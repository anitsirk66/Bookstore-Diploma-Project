@using BookstoreProjectData.Entities
@using Microsoft.AspNetCore.Identity
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookstoreWebApp</title>
    <link rel="stylesheet" href="~/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/font-awesome.min.css" />
    <link rel="stylesheet" href="~/css/templatemo-style.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BookstoreWebApp.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&display=swap" rel="stylesheet">
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark shadow-sm" style="background:#FC466B;">
            <div class="container">

                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <img src="~/img/bookLogo.png" alt="Pink Sunrise" style="height:45px;" />
                </a>

                <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#nav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="nav">
                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Books" asp-action="Index">Books</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Events" asp-action="Index">Events</a>
                        </li>

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item text-white">
                                <a class="nav-link text-white" asp-controller="Authors" asp-action="Index">Authors</a>
                            </li>
                            <li class="nav-item text-white">
                                <a class="nav-link text-white" asp-controller="Genres" asp-action="Index">Genres</a>
                            </li>
                            <li class="nav-item text-white">
                                <a class="nav-link" asp-controller="Publishers" asp-action="Index">Publishers</a>
                            </li>
                        }
                    </ul>

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>


    @if (TempData["SuccessMessage"] != null)
    {
        <div>
            <div class="alert alert-success alert-dismissible fade show">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div>
            <div class="alert alert-danger alert-dismissible fade show">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (!ViewData.ModelState.IsValid && Context.Request.Method == "POST")
    {
        <div>
            @foreach (var item in ViewData.ModelState)
            {
                if (item.Value.Errors.Any())
                {
                    <div class="alert alert-danger alert-dismissible fade show">
                        <p><b>Field:</b> <span class="fst-italic">@item.Key</span></p>
                        <p><b>Error:</b> <span class="fst-italic">@string.Join("; ", item.Value.Errors.Select(x => x.ErrorMessage))</span></p>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
            }
        </div>
    }

    <div class="">
        <main class="flex-fill">
            @RenderBody()
        </main>
    </div>
    @if (!User.Identity.IsAuthenticated || User.IsInRole("Client"))
    {
        <footer class="class=footer mt-auto pt-4 pb-3">
            <div class="container">

                <div class="row text-center text-md-start">

                    <div class="col-md-4 mb-3">
                        <h5 class="fw-bold">📚 Pink Sunrise</h5>
                        <p class="small">
                            Discover stories, meet authors, and enjoy curated monthly picks.
                        </p>
                    </div>

                    <div class="col-md-4 mb-3">
                        <h6 class="fw-bold">Quick Links</h6>
                        <ul class="list-unstyled">
                            <li><a asp-controller="Books" asp-action="Index">Books</a></li>
                            <li><a asp-controller="Events" asp-action="Index">Events</a></li>
                            <li><a asp-controller="Home" asp-action="Details">About</a></li>
                        </ul>
                    </div>

                    <div class="col-md-4 mb-3">
                        <h6 class="fw-bold">Contact</h6>
                        <p class="small mb-1">📧 contact@pinksunrise.com</p>
                        <p class="small mb-0">📍 Kazanlak, Bulgaria</p>
                    </div>

                </div>

                <hr />

                <div class="text-center small">
                    © 2026 Pink Sunrise. All rights reserved.
                </div>
            </div>
        </footer>
    }
    <script src="~/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/templatemo-script.js"></script>
    <script src="~/js/jquery-1.11.2.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
