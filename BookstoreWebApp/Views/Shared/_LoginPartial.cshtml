
@using BookstoreProjectData.Entities
@using Microsoft.AspNetCore.Identity
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager

<ul class="navbar-nav tm-nav">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <a  class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage"><img src="~/img/user.png" width="20" height="20"/></a>
    </li>
        <li class="nav-item">
            <a class="nav-link text-dark" asp-controller="Orders" asp-action="AddToCart"><img src="~/img/parcel.png" width="20" height="20" /></a>
        </li>
    <li class="nav-item">
        <a class="nav-link text-dark" asp-controller="User" asp-action="Logout">Logout</a>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-dark" asp-controller="User" asp-action="Register">Register</a>
    </li>
    <li class="nav-item">
            <a class="nav-link text-dark" asp-controller="User" asp-action="Login">Login</a>
    </li>
}
</ul>
