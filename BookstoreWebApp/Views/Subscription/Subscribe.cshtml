@using BookstoreProjectCore.Models.Subscription
@model SubscriptionViewModel

<div class="container mt-5">
    <div class="card p-4 shadow" style="max-width: 500px; margin:auto;">

        <h3 class="text-center mb-4">📦 Subscription</h3>

        <form asp-action="Subscribe" method="post">

            <div class="mb-3">
                <label class="form-label">Delivery Address</label>
                <input asp-for="Address" class="form-control" />
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>

            <button class="btn btn-danger w-100">
                Subscribe – 19.99€/month
            </button>

        </form>
    </div>
</div>
