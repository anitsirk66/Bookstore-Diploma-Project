@using BookstoreProjectCore.Models.Books
@using BookstoreProjectData.Entities
@model IEnumerable<BooksIndexViewModel>


<div class="container mt-4">

    <h2 class="text-center mb-4">📚 Books of the Month</h2>

    <div class="text-center mb-4">
        @if (User.Identity.IsAuthenticated && User.IsInRole("Client"))
        {
            @if (ViewBag.IsSubscribed == true)
            {
                <span class="btn btn-success">Subscribed</span>
            }
            else
            {
                <a asp-controller="Subscription" asp-action="Subscribe" class="btn btn-danger">Subscribe</a>
            }
        }
    </div>

    @if (User.IsInRole("Admin"))
    {
        <div class="text-center mb-4">
            <a asp-controller="Subscription" asp-action="EditBooks" class="btn btn-warning">
                Change Subscription Books
            </a>
        </div>
    }

    @if (!Model.Any())
    {
        <p class="text-center">No books selected for this month.</p>
    }
    else
    {
        <div class="books-grid-subscription">
            @foreach (var book in Model)
            {
                <div class="book-card-subscription text-center">
                    <a asp-action="Details" asp-controller="Books" asp-route-id="@book.Id" class="book-click">
                        <img src="@book.CoverImageUrl" class="book-img-subscription mb-2" />
                        <div class="card-body">
                            <h5>@book.Title</h5>
                            <p class="text-muted">@book.AuthorName</p>
                            <p class="price">@book.Price €</p>
                        </div>
                    </a>

                    @if (User.Identity.IsAuthenticated && User.IsInRole("Client"))
                    {
                        <a asp-controller="Orders" asp-action="AddToCart"
                           asp-route-id="@book.Id"
                           asp-route-bookId=""
                           class="btn btn-danger">
                            Add to Cart
                        </a>
                    }
                </div>
            }
        </div>
        @if (ViewBag.Price != null)
        {
            <h4 class="text-center text-success mb-3">
                Subscription Price: @ViewBag.Price €
            </h4>
        }
    }

</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
