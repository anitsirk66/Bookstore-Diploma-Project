@using BookstoreProjectCore.Models.Events;
@model IEnumerable<EventsIndexViewModel>


<div class="container my-5 text-center">
    <h2 class="fw-bold">📅 Upcoming Events</h2>
    <p class="text-muted">Meet your favorite authors</p>

    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary mt-3">
            + Add Event
        </a>
    }
</div>

<div class="tm-main-section light-gray-bg mt-2">
    <div class="container" id="main">
        <section class="tm-section tm-section-margin-bottom-0 row mt-2">
            <div class="col-lg-12 tm-section-header-container">
                <h2 class="tm-section-header gold-text tm-handwriting-font"> Popular Events</h2>
                <div class="tm-hr-container"><hr class="tm-hr"></div>
            </div>
            <div class="col-lg-12 tm-popular-items-container">
                <div class="row g-4">
                    @foreach (var e in Model)
                    {
                        <div class="col-12 col-sm-6 col-lg-4">
                            <div class="card event-card h-100 shadow-sm">

                                <div class="card-body d-flex flex-column">

                                    <h5 class="fw-bold mb-2">@e.Name</h5>

                                    <p class="text-muted small mb-2">
                                        📅 @e.DateAndTime.ToString("dd MMM yyyy, HH:mm")
                                    </p>

                                    <p class="mb-3">
                                        ✍️ @e.AuthorName
                                    </p>

                                    <div class="mt-auto">

                                        @if (User.IsInRole("Admin"))
                                        {
                                            <div class="d-flex gap-2">
                                                <a asp-action="Edit"
                                                   asp-route-id="@e.Id"
                                                   class="btn btn-warning btn-sm w-100">
                                                    Edit
                                                </a>

                                                <form asp-action="Delete"
                                                      method="post"
                                                      asp-route-id="@e.Id"
                                                      class="w-100">
                                                    <button class="btn btn-danger btn-sm w-100">
                                                        Delete
                                                    </button>
                                                </form>
                                            </div>
                                        }
                                        else
                                        {
                                            <a href="@e.Link"
                                               target="_blank"
                                               class="btn btn-dark w-100">
                                                View Event
                                            </a>
                                        }

                                    </div>

                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </section>
    </div>
</div>